{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "SANGAM default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-read-dir",
    "shell:default",
    "shell:allow-open"
  ]
}
